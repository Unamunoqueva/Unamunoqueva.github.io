  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-3 font-mono text-xs text-[var(--color-muted)] sm:flex-row sm:items-center"
  >
    <p>
      <span class="text-[var(--color-accent)]">©</span>
      {year} José Luis Lupiáñez Serrano — Málaga, España
    </p>
    <p>
      Hecho con Astro + Tailwind · desplegado con GitHub Pages
    </p>
  </div>
</footer>
